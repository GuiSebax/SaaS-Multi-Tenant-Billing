# ── Banco de dados ────────────────────────────────────────────────────────────
# Para Docker: usa o nome do serviço como hostname (postgres)
# Para local sem Docker: postgresql://app_user:dev_password@localhost:5432/saas_dev
DATABASE_URL=postgresql://app_user:dev_password@postgres:5432/saas_dev

# URL do superuser — usada APENAS em testes de integração para setup do banco.
# Nunca usada pela aplicação em runtime.
# Para Docker: DATABASE_ADMIN_URL=postgresql://postgres:postgres@postgres:5432/saas_dev
DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/saas_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# Para Docker: usa o nome do serviço como hostname (redis)
# Para local sem Docker: redis://localhost:6379
REDIS_URL=redis://redis:6379

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres — gere com: openssl rand -hex 32
JWT_SECRET=change_me_minimum_32_characters_long_replace_in_production
JWT_REFRESH_SECRET=change_me_minimum_32_characters_long_also_replace

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
